    "@graphql-tools/utils": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "graphql": "^16.13.1",
    "typescript": "^5.0.0",
    "zod": "^3.25.0"
  }
}
